<#
.SYNOPSIS
    This PowerShell script ensures that in the registry, AlwaysInstallElevated is set to 0
.NOTES
    Author          : Hugh Black
    LinkedIn        : linkedin.com/in/hugh-black/
    GitHub          : github.com/hblack5676
    Date Created    : 2026-06-20
    Last Modified   : 2026-06-20
    Version         : 1.0
    CVEs            : N/A
    Plugin IDs      : N/A
    STIG-ID         : WN11-CC-000315
    Documentation   : 

.TESTED ON
    Date(s) Tested  : 
    Tested By       : 
    Systems Tested  : 
    PowerShell Ver. : 

.USAGE
    Put any usage instructions here.

# Run PowerShell as Administrator

$Path = "HKLM:\SOFTWARE\Policies\Microsoft\Windows\Installer"
$Name = "AlwaysInstallElevated"

if (!(Test-Path $Path)) {
    New-Item -Path $Path -Force | Out-Null
}

New-ItemProperty -Path $Path -Name $Name -Value 0 -PropertyType DWord -Force | Out-Null

# Verify
Get-ItemProperty -Path $Path -Name $Name
#>
