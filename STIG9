<#
.SYNOPSIS
    This PowerShell scriptp prevents the local system account from falling back to Null session when NTLM authentication fails.
    Author          : Hugh Black
    LinkedIn        : linkedin.com/in/hugh-black/
    GitHub          : github.com/hblack5676
    Date Created    : 2026-06-23
    Last Modified   : 2026-06-23
    Version         : 1.0
    CVEs            : N/A
    Plugin IDs      : N/A
    STIG-ID         : WN11-SO-000180
    Documentation   : 

.TESTED ON
    Date(s) Tested  : 
    Tested By       : 
    Systems Tested  : 
    PowerShell Ver. : 

.USAGE
    Put any usage instructions here.
$Path = "HKLM:\SYSTEM\CurrentControlSet\Control\Lsa\MSV1_0"
$Name = "allownullsessionfallback"

if (!(Test-Path $Path)) {
    New-Item -Path $Path -Force | Out-Null
}

New-ItemProperty -Path $Path `
    -Name $Name `
    -Value 0 `
    -PropertyType DWord `
    -Force | Out-Null

# Verify
Get-ItemProperty -Path $Path -Name $Name
