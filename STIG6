.SYNOPSIS
    This PowerShell script requires windows to log the actual PoweShell commands and scripts that are executed
    Author          : Hugh Black
    LinkedIn        : linkedin.com/in/hugh-black/
    GitHub          : github.com/hblack5676
    Date Created    : 2026-06-21
    Last Modified   : 2026-06-21
    Version         : 1.0
    CVEs            : N/A
    Plugin IDs      : N/A
    STIG-ID         : WN11-CC-000326
    Documentation   : 

.TESTED ON
    Date(s) Tested  : 
    Tested By       : 
    Systems Tested  : 
    PowerShell Ver. : 

.USAGE
    Put any usage instructions here.
$Path = "HKLM:\SOFTWARE\Policies\Microsoft\Windows\PowerShell\ScriptBlockLogging"
$Name = "EnableScriptBlockLogging"

if (!(Test-Path $Path)) {
    New-Item -Path $Path -Force | Out-Null
}

New-ItemProperty -Path $Path -Name $Name -Value 1 -PropertyType DWord -Force | Out-Null

# Verify the setting
Get-ItemProperty -Path $Path -Name $Name
