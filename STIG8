<#
.SYNOPSIS
    This PowerShell script enables PowerShell transcription. Transcription records PowerShell sessions to text files, providing a detailed audit trail of commands and output.
    Author          : Hugh Black
    LinkedIn        : linkedin.com/in/hugh-black/
    GitHub          : github.com/hblack5676
    Date Created    : 2026-06-23
    Last Modified   : 2026-06-23
    Version         : 1.0
    CVEs            : N/A
    Plugin IDs      : N/A
    STIG-ID         : WN11-CC-000327
    Documentation   : 

.TESTED ON
    Date(s) Tested  : 
    Tested By       : 
    Systems Tested  : 
    PowerShell Ver. : 

.USAGE
    Put any usage instructions here.
$Path = "HKLM:\SOFTWARE\Policies\Microsoft\Windows\PowerShell\Transcription"

if (!(Test-Path $Path)) {
    New-Item -Path $Path -Force | Out-Null
}

# Enable PowerShell Transcription
New-ItemProperty -Path $Path -Name "EnableTranscripting" -Value 1 -PropertyType DWord -Force | Out-Null

# Optional but recommended by DISA:
# Set a transcript output directory
New-ItemProperty -Path $Path -Name "OutputDirectory" `
    -Value "C:\PowerShellTranscripts" `
    -PropertyType String -Force | Out-Null

# Create the directory if needed
New-Item -ItemType Directory -Path "C:\PowerShellTranscripts" -Force | Out-Null

# Verify
Get-ItemProperty -Path $Path
